{
  "name": "tour-booking-backend",
  "version": "1.0.0",
  "description": "Backend API cho hệ thống website bán tour du lịch",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec vite-node src/server.ts",
    "build": "vite build",
    "start": "node dist/server.js",
    "test:db": "node test-connection.cjs",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:new": "node database/seed-helper.js seed:new",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:seed:check": "node database/seed-helper.js check",
    "db:reset": "node database/seed-helper.js reset",
    "db:reset:hard": "node database/reset-db.js",
    "db:add-fullname-admin": "node database/add-fullname-admin.cjs",
    "db:add-timestamps-roles": "node database/add-timestamps-to-roles.cjs",
    "db:add-tour-id-tickets": "node database/add-tour-id-to-tickets.cjs",
    "db:fix-tickets": "node database/fix-tickets-table.cjs"
  },
  "keywords": [
    "tour",
    "booking",
    "travel",
    "nodejs",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "nodemon": "^3.1.11",
    "sequelize": "^6.35.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.4",
    "@types/socket.io": "^3.0.1",
    "sequelize-cli": "^6.6.2",
    "typescript": "^5.3.3",
    "vite": "^7.0.0",
    "vite-node": "^2.1.8",
    "vite-plugin-node": "^7.0.0"
  }
}
